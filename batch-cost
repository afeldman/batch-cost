#!/usr/bin/env bash

set -euo pipefail 

export LC_NUMERIC=C 
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)" 
JOB_QUEUE="${JOB_QUEUE:-}"
if [[ -z "${JOB_QUEUE:-}" ]]; then
  JOB_QUEUE=$(aws batch describe-job-queues \
    --query 'jobQueues[0].jobQueueName' \
    --output text 2>/dev/null)

  [[ -z "$JOB_QUEUE" || "$JOB_QUEUE" == "None" ]] && \
    err "Keine Batch Queue gefunden"
fi

# debug optional
echo "SCRIPT_DIR=$SCRIPT_DIR" 

source "$SCRIPT_DIR/lib/output.sh" || exit 1 
source "$SCRIPT_DIR/lib/pricing.sh" || exit 1 
source "$SCRIPT_DIR/lib/validate.sh" || exit 1 
source "$SCRIPT_DIR/lib/batch-cost.sh" || exit 1 
source "$SCRIPT_DIR/providers/aws.sh" || exit 1 

echo "load pricing..." 
load_pricing 
echo "pricing loaded: vCPU \$$PRICE_PER_VCPU_HOUR / GB \$$PRICE_PER_GB_HOUR"

format_float() {
  local val="$1"
  [[ "$val" =~ ^\..* ]] && val="0$val"
  LC_NUMERIC=C printf "%.4f" "$val"
}

calc_cost_with_prices() {
  local duration="$1"
  local vcpu="$2"
  local memory="$3"
  local cpu_price="$4"
  local mem_price="$5"

  local duration_h memory_gb

  duration_h=$(echo "scale=6; $duration / 3600" | bc)
  memory_gb=$(echo "scale=6; $memory / 1024" | bc)

  local cpu_cost mem_cost total

  cpu_cost=$(echo "$vcpu * $duration_h * $cpu_price" | bc)
  mem_cost=$(echo "$memory_gb * $duration_h * $mem_price" | bc)
  total=$(echo "$cpu_cost + $mem_cost" | bc)

  echo "$total"
}

aws_list_jobs() {
  aws batch list-jobs \
    --job-queue "$JOB_QUEUE" \
    --job-status SUCCEEDED \
    --max-items "$1" \
    --output json | \
  jq -r '.jobSummaryList[].jobId'
}

mode_estimate() {
  local job_id="$1"

  local job_data
  job_data=$(aws_describe_job "$job_id")

  local duration_sec vcpu memory_mb status
  duration_sec=$(echo "$job_data" | jq -r '.duration_sec')
  vcpu=$(echo "$job_data" | jq -r '.vcpu')
  memory_mb=$(echo "$job_data" | jq -r '.memory_mb')
  status=$(echo "$job_data" | jq -r '.status')

  validate_number "duration" "$duration_sec"
  validate_number "vcpu" "$vcpu"
  validate_number "memory_mb" "$memory_mb"

  duration_sec=$(sanitize_duration "$duration_sec")

  IFS="|" read -r cpu_cost mem_cost total cost_per_hour \
    <<< "$(calc_cost_raw "$duration_sec" "$vcpu" "$memory_mb")"

  # --- Drift ---
  static_total=$(calc_cost_with_prices \
    "$duration_sec" "$vcpu" "$memory_mb" \
    "$DEFAULT_VCPU_PRICE" "$DEFAULT_GB_PRICE")

  live_total="$total"
  delta=$(echo "$live_total - $static_total" | bc)

  if (( $(echo "$static_total > 0" | bc -l) )); then
    delta_pct=$(echo "scale=2; ($delta / $static_total) * 100" | bc)
  else
    delta_pct=0
  fi

  # --- Format ---
  cpu_cost_fmt=$(format_float "$cpu_cost")
  mem_cost_fmt=$(format_float "$mem_cost")
  total_fmt=$(format_float "$total")
  cph_fmt=$(format_float "$cost_per_hour")

  static_fmt=$(format_float "$static_total")
  live_fmt=$(format_float "$live_total")
  delta_fmt=$(format_float "$delta")

  # --- Insights ---
  if (( $(echo "$total == 0" | bc -l) )); then
    cpu_pct=0
    mem_pct=0
  else
    cpu_pct=$(echo "scale=2; $cpu_cost / $total * 100" | bc)
    mem_pct=$(echo "scale=2; $mem_cost / $total * 100" | bc)
  fi

  echo ""
  header "Batch Cost v2"
  echo ""

  label "Pricing Source" "$PRICING_SOURCE"
  label "Job ID" "$job_id"
  label "Status" "$status"
  label "Duration" "$(format_duration "$duration_sec")"
  label "vCPU" "$vcpu"
  label "Memory" "$memory_mb MB"

  separator

  cost_line "CPU Cost" "$cpu_cost_fmt"
  cost_line "Memory Cost" "$mem_cost_fmt"
  cost_line "Total" "$total_fmt"

  separator

  label "Cost / Hour" "\$$cph_fmt"
  label "CPU %" "$cpu_pct%"
  label "Memory %" "$mem_pct%"

  separator
  label "Static Cost" "\$$static_fmt"
  label "Live Cost"   "\$$live_fmt"
  label "Delta"       "$(color_delta "$delta_fmt" "$delta_pct")"

  echo ""

  if (( $(echo "$cpu_pct > 70" | bc -l) )); then
    warn "CPU dominiert → evtl. overprovisioned"
  fi

  if (( $(echo "$mem_pct > 70" | bc -l) )); then
    warn "Memory dominiert → evtl. RAM zu hoch"
  fi

  echo ""
}


mode_multi() {
    echo "[DEBUG] Starting multi job analysis with limit: ${LIMIT:-10}"
  local limit="${LIMIT:-10}"

  echo ""
  header "Multi Job Analysis for Queue: $JOB_QUEUE (Limit: $limit)"
  echo ""

  local total_cost=0
  local max_cost=0
  local count=0

  local job_ids
  job_ids=$(aws_list_jobs "$limit")

  if [[ -z "$job_ids" ]]; then
    err "Keine Jobs gefunden (Queue: $JOB_QUEUE)"
  fi

  echo "[DEBUG] Job IDs fetched:"
  echo "$job_ids"

  for job_id in $job_ids; do
    local job_data duration_sec vcpu memory_mb total

    job_data=$(aws_describe_multi_job "$job_id")

    duration_sec=$(echo "$job_data" | jq -r '.duration_sec')
    vcpu=$(echo "$job_data" | jq -r '.vcpu')
    memory_mb=$(echo "$job_data" | jq -r '.memory_mb')

    echo "[DEBUG] job_id=$job_id"
    echo "[DEBUG] duration=$duration_sec vcpu=$vcpu mem=$memory_mb"

    # skip invalid
    if [[ "$duration_sec" == "null" || -z "$duration_sec" ]]; then
      continue
    fi

    duration_sec=$(sanitize_duration "$duration_sec")

    IFS="|" read -r _ _ total _ \
      <<< "$(calc_cost_raw "$duration_sec" "$vcpu" "$memory_mb")"

    total_cost=$(echo "$total_cost + $total" | bc)

    if (( $(echo "$total > $max_cost" | bc -l) )); then
      max_cost="$total"
    fi

    count=$((count + 1))
  done

  echo "[DEBUG] Jobs analyzed: $count"

  if [[ "$count" -eq 0 ]]; then
    err "Keine validen Jobs gefunden"
  fi

  local avg_cost
  avg_cost=$(echo "scale=4; $total_cost / $count" | bc)

  separator
  label "Jobs analyzed" "$count"
  separator
  cost_line "Total Cost" "$(format_float "$total_cost")"
  cost_line "Average"    "$(format_float "$avg_cost")"
  cost_line "Max Job"    "$(format_float "$max_cost")"

  echo ""
}

case "$1" in
  --last)
    LIMIT="$2"
    mode_multi
    ;;
  *)
    mode_estimate "$1"
    ;;
esac
